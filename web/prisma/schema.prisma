generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Comment {
  id            String       @id @db.Uuid
  authorId      String       @db.Uuid
  content       String
  targetType    TargetType
  wikiArticleId String?      @db.Uuid
  questionId    String?      @db.Uuid
  createdAt     DateTime     @default(now())
  updatedAt     DateTime
  deletedAt     DateTime?
  User          User         @relation(fields: [authorId], references: [id])
  Question      Question?    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  WikiArticle   WikiArticle? @relation(fields: [wikiArticleId], references: [id], onDelete: Cascade)

  @@index([targetType, questionId])
  @@index([targetType, wikiArticleId])
}

model EditRequest {
  id                                String       @id @db.Uuid
  proposerId                        String       @db.Uuid
  reviewerId                        String?      @db.Uuid
  targetType                        TargetType
  patchJson                         Json
  status                            EditStatus   @default(PENDING)
  note                              String?
  createdAt                         DateTime     @default(now())
  updatedAt                         DateTime
  wikiArticleId                     String?      @db.Uuid
  questionId                        String?      @db.Uuid
  User_EditRequest_proposerIdToUser User         @relation("EditRequest_proposerIdToUser", fields: [proposerId], references: [id])
  Question                          Question?    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  User_EditRequest_reviewerIdToUser User?        @relation("EditRequest_reviewerIdToUser", fields: [reviewerId], references: [id])
  WikiArticle                       WikiArticle? @relation(fields: [wikiArticleId], references: [id], onDelete: Cascade)

  @@index([proposerId])
  @@index([status])
}

model ParsedDraft {
  id               String      @id @db.Uuid
  jobId            String      @unique
  originalUrl      String
  originalFilename String?
  draftJson        Json
  status           DraftStatus @default(PROCESSING)
  errorLog         String?
  geminiMeta       Json?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime

  @@index([jobId])
  @@index([status])
}

model Question {
  id                 String                 @id @db.Uuid
  year               Int?
  examType           String?
  stem               String
  options            Json
  answer             String
  explanation        String?
  imageUrls          String[]
  difficulty         Int                    @default(1)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime
  deletedAt          DateTime?
  wikiArticleId      String?                @db.Uuid
  embedding          Unsupported("vector")?
  Comment            Comment[]
  EditRequest        EditRequest[]
  WikiArticle        WikiArticle?           @relation(fields: [wikiArticleId], references: [id])
  QuestionTag        QuestionTag[]
  UserQuestionRecord UserQuestionRecord[]

  @@index([deletedAt])
  @@index([embedding], map: "Question_embedding_hnsw_idx")
  @@index([wikiArticleId])
  @@index([year, examType])
}

model QuestionTag {
  questionId String   @db.Uuid
  tagId      String   @db.Uuid
  Question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  Tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([questionId, tagId])
}

model Tag {
  id          String        @id @db.Uuid
  name        String
  slug        String        @unique
  dimension   TagDimension
  groupName   String?
  QuestionTag QuestionTag[]
  WikiTag     WikiTag[]

  @@unique([dimension, groupName, name])
  @@index([dimension, groupName])
}

model User {
  id                                       String               @id @db.Uuid
  email                                    String               @unique
  name                                     String?
  passwordHash                             String               @default("")
  role                                     Role                 @default(USER)
  createdAt                                DateTime             @default(now())
  deletedAt                                DateTime?
  Comment                                  Comment[]
  EditRequest_EditRequest_proposerIdToUser EditRequest[]        @relation("EditRequest_proposerIdToUser")
  EditRequest_EditRequest_reviewerIdToUser EditRequest[]        @relation("EditRequest_reviewerIdToUser")
  UserIntegration                          UserIntegration[]
  UserQuestionRecord                       UserQuestionRecord[]
  WikiArticle                              WikiArticle[]

  @@index([email])
}

model UserIntegration {
  id                   String              @id @db.Uuid
  userId               String              @db.Uuid
  provider             IntegrationProvider
  accessTokenEncrypted String
  metadata             Json?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime
  User                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

model UserQuestionRecord {
  id           String    @id @db.Uuid
  userId       String    @db.Uuid
  questionId   String    @db.Uuid
  userAnswer   String
  isCorrect    Boolean
  easeFactor   Float     @default(2.5)
  interval     Int       @default(0)
  repetitions  Int       @default(0)
  nextReviewAt DateTime  @default(now())
  answeredAt   DateTime  @default(now())
  deletedAt    DateTime?
  Question     Question  @relation(fields: [questionId], references: [id])
  User         User      @relation(fields: [userId], references: [id])

  @@index([userId, nextReviewAt])
  @@index([userId, questionId])
}

model WikiArticle {
  id          String                 @id @db.Uuid
  title       String
  content     String
  status      ArticleStatus          @default(DRAFT)
  authorId    String                 @db.Uuid
  createdAt   DateTime               @default(now())
  updatedAt   DateTime
  deletedAt   DateTime?
  embedding   Unsupported("vector")?
  Comment     Comment[]
  EditRequest EditRequest[]
  Question    Question[]
  User        User                   @relation(fields: [authorId], references: [id])
  WikiTag     WikiTag[]

  @@index([authorId])
  @@index([embedding], map: "WikiArticle_embedding_hnsw_idx")
  @@index([status, deletedAt])
}

model WikiTag {
  wikiArticleId String      @db.Uuid
  tagId         String      @db.Uuid
  Tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)
  WikiArticle   WikiArticle @relation(fields: [wikiArticleId], references: [id], onDelete: Cascade)

  @@id([wikiArticleId, tagId])
}

enum ArticleStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  ARCHIVED
}

enum DraftStatus {
  PROCESSING
  AWAITING_REVIEW
  APPROVED
  REJECTED
}

enum EditStatus {
  PENDING
  APPROVED
  REJECTED
}

enum IntegrationProvider {
  NOTION
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

enum TagDimension {
  ACADEMIC
  ORGAN
  EXAM_CATEGORY
  META
}

enum TargetType {
  WIKI_ARTICLE
  QUESTION
}
